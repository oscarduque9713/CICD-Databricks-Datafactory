{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfsprojectosc97dev"
		},
		"akvdev_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kvprojectosc13.vault.azure.net/"
		},
		"ls_adb_prod_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0414-175402-ycrjrf77"
		},
		"ls_adb_dev_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "@cluster"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfsprojectosc97dev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"akvdev_properties_typeProperties_baseUrl": {
						"value": "[parameters('akvdev_properties_typeProperties_baseUrl')]"
					},
					"ls_adb_prod_properties_typeProperties_existingClusterId": {
						"value": "[parameters('ls_adb_prod_properties_typeProperties_existingClusterId')]"
					},
					"ls_adb_dev_properties_typeProperties_existingClusterId": {
						"value": "[parameters('ls_adb_dev_properties_typeProperties_existingClusterId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}